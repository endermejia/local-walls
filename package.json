{
  "name": "climbeast",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --hmr=false",
    "start:hmr": "ng serve",
    "build": "ng build",
    "serve:ssr:climbeast": "bun dist/climbeast/server/server.mjs",
    "watch": "ng build --watch --configuration development",
    "supabase:init": "bunx supabase login",
    "gen:supabase-types": "bunx supabase gen types typescript --project-id \"eswbehepsagigvlytfxv\" --schema public,storage,auth > src/models/supabase-generated.ts",
    "test": "ng test",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "format": "prettier --write ./src",
    "check:i18n": "node scripts/check-translations.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,html,css,scss,md,json}": [
      "prettier --write"
    ]
  },
  "private": true,
